{
  "info": {
    "_postman_id": "example-security-api",
    "name": "Example Vulnerable API",
    "description": "Sample API collection for security testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.example.com",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/users",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "v1", "users"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ]
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/users/123",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "v1", "users", "123"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_token}}",
                "type": "text"
              }
            ]
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/users",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "v1", "users"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/api/v1/users/123",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "v1", "users", "123"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/users/123",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "v1", "users", "123"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_token}}",
                "type": "text"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/products",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "v1", "products"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ]
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/products/search?q=laptop",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "v1", "products", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "laptop"
                }
              ]
            },
            "header": []
          }
        },
        {
          "name": "Get Product Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/products/456",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "v1", "products", "456"]
            },
            "header": []
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/orders",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "v1", "orders"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_token}}",
                "type": "text"
              }
            ]
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/orders",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "v1", "orders"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"product_id\": 456,\n      \"quantity\": 2\n    }\n  ],\n  \"shipping_address\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"Anytown\",\n    \"zip\": \"12345\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get Order Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/orders/789",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "v1", "orders", "789"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_token}}",
                "type": "text"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get System Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/status",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "admin", "status"]
            },
            "header": [
              {
                "key": "X-Admin-Token",
                "value": "admin_secret_123",
                "type": "text"
              }
            ]
          }
        },
        {
          "name": "Get Database Info",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/database",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["api", "admin", "database"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_token}}",
                "type": "text"
              }
            ]
          }
        }
      ]
    }
  ]
}
